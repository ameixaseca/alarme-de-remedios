{
  "name": "dailymed",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">  =10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@dailymed/web",
    "dev:mobile": "turbo dev --filter=@dailymed/mobile"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "metro": "0.81.5",
      "metro-cache": "0.81.5",
      "metro-cache-key": "0.81.5",
      "metro-config": "0.81.5",
      "metro-core": "0.81.5",
      "metro-file-map": "0.81.5",
      "metro-babel-transformer": "0.81.5",
      "metro-minify-terser": "0.81.5",
      "metro-resolver": "0.81.5",
      "metro-transform-worker": "0.81.5",
      "metro-transform-plugins": "0.81.5",
      "metro-source-map": "0.81.5",
      "metro-runtime": "0.81.5"
    }
  }
}