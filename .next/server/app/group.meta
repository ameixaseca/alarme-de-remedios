{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/group/layout,_N_T_/(app)/group/page,_N_T_/group"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/group/__PAGE__",
    "/!KGFwcCk/group",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}